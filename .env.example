# Copy this file to .env and fill in your values
# NEVER commit .env to git

# PostgreSQL Connection
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/revops_database

# DBT-specific variables
DBT_POSTGRES_USER=YOUR_USER
DBT_POSTGRES_PASSWORD=YOUR_PASSWORD
DBT_POSTGRES_HOST=localhost
DBT_POSTGRES_PORT=5432

# Individual settings (optional, used if DATABASE_URL not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=YOUR_USER
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_DB=revops_database

# CI/CD Environments
CI_DB_HOST=your_ci_database_host
CI_DB_USER=your_ci_database_user
CI_DB_PASSWORD=your_ci_database_password

PROD_DB_HOST=your_prod_database_host
PROD_DB_USER=your_prod_database_user
PROD_DB_PASSWORD=your_prod_database_password
