# ~/.dbt/profiles.yml
# WARNING: Never commit this file to Version Control (Git).
# It contains sensitive credentials managed via Environment Variables.

revops_project:
  # The default environment that dbt will use if no --target is specified
  target: dev_duckdb 
  
  outputs:

    # ---------------------------------------------------------
    # DEVELOPMENT: Local Analytics using DuckDB (Fast & Cheap)
    # ---------------------------------------------------------
    dev_duckdb:
      type: duckdb
      path: './duckdb/revops_analytics.duckdb' # Local database file path
      schema: revops_marts                   # Default schema for transformed data
      threads: 4                             # Parallel execution threads
      extensions:
        - postgres                           # Required to scan data from Postgres
      settings:
        preserve_insertion_order: false      # Optimization for faster data loading

    # ---------------------------------------------------------
    # LOCAL POSTGRES: Direct connection to your local DB
    # ---------------------------------------------------------
    dev_postgres:
      type: postgres
      host: localhost
      port: 5432
      user: "{{ env_var('DBT_POSTGRES_USER') }}"      # Fetched from your terminal env
      pass: "{{ env_var('DBT_POSTGRES_PASSWORD') }}"  # Fetched from your terminal env
      dbname: revops_database
      schema: raw                                     # Target schema for raw ingestion
      threads: 4

    # ---------------------------------------------------------
    # CI (Continuous Integration): Automated testing in GitHub/GitLab
    # ---------------------------------------------------------
    ci:
      type: postgres
      host: "{{ env_var('CI_DB_HOST') }}"     # Provided by CI/CD Runner
      port: 5432
      user: "{{ env_var('CI_DB_USER') }}"
      pass: "{{ env_var('CI_DB_PASSWORD') }}"
      dbname: revops_database
      schema: dbt_ci_test                     # Isolated schema for testing
      threads: 2                              # Lower threads for CI stability

    # ---------------------------------------------------------
    # PRODUCTION: Final Cloud-based Data Warehouse (The "Source of Truth")
    # ---------------------------------------------------------
    prod:
      type: postgres
      host: "{{ env_var('PROD_DB_HOST') }}"   # Production Database URL
      port: 5432
      user: "{{ env_var('PROD_DB_USER') }}"
      pass: "{{ env_var('PROD_DB_PASSWORD') }}"
      dbname: revops_database
      schema: analytics                       # Final cleaned schema for BI tools
      threads: 8                              # High concurrency for large data volumes