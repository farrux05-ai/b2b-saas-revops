# Copy to ~/.dbt/profiles.yml and fill in your credentials.
# Never commit profiles.yml to git — it contains secrets.

revops_project:
  target: dev
  outputs:

    dev:
      type: postgres
      host: localhost
      port: 5432
      user: "{{ env_var('POSTGRES_USER') }}"
      password: "{{ env_var('POSTGRES_PASSWORD') }}"
      dbname: revops_database
      schema: raw
      threads: 4

    ci:
      type: postgres
      host: "{{ env_var('CI_DB_HOST') }}"
      port: 5432
      user: "{{ env_var('CI_DB_USER') }}"
      password: "{{ env_var('CI_DB_PASSWORD') }}"
      dbname: revops_database
      schema: raw
      threads: 2

    prod:
      type: postgres
      host: "{{ env_var('PROD_DB_HOST') }}"
      port: 5432
      user: "{{ env_var('PROD_DB_USER') }}"
      password: "{{ env_var('PROD_DB_PASSWORD') }}"
      dbname: revops_database
      schema: raw
      threads: 8
